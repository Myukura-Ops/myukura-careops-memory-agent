# ── Core API Configuration ────────────────────────────────────────
APP_ENV=local
STATE_BACKEND=memory
DEMO_MODE=true
DEMO_ACCESS_CODE=CHANGE_ME_FOR_DEMO
DEMO_ACCESS_REQUIRED=true
MAX_SOURCE_NOTE_CHARS=6000

# ── MongoDB Atlas ─────────────────────────────────────────────────
MONGODB_URI=YOUR_MONGODB_ATLAS_URI
MONGODB_DATABASE=myukura_careops_demo
MONGODB_CONNECT_TIMEOUT_MS=5000
MONGODB_APP_NAME=myukura-careops-memory-agent

# ── Gemini Orchestrator ───────────────────────────────────────────
GEMINI_ENABLED=false
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_PRIMARY_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-3.5-pro
GEMINI_MAX_MODEL_ATTEMPTS=3
GEMINI_REQUEST_TIMEOUT_SECONDS=20

# Partner Outbox settings
PARTNER_OUTBOX_ENABLED=true
PARTNER_MAX_ATTEMPTS=3
PARTNER_EXPORT_TIMEOUT_SECONDS=10

# Demo Quota Guard
DEMO_QUOTA_ENABLED=true
MAX_DEMO_RUNS_PER_DAY=50
MAX_DEMO_GEMINI_RUNS_PER_DAY=25
MAX_DEMO_PARTNER_WORKER_CALLS_PER_DAY=20
MAX_DEMO_SEED_CALLS_PER_DAY=5
MAX_DEMO_TASK_MUTATIONS_PER_DAY=100

# ── CORS ──────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
