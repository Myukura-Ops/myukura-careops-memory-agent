# ── Core API Configuration ────────────────────────────────────────
APP_ENV=local
STATE_BACKEND=memory
DEMO_MODE=true
DEMO_ACCESS_CODE=CHANGE_ME_FOR_DEMO
DEMO_ACCESS_REQUIRED=true
MAX_SOURCE_NOTE_CHARS=6000

# ── MongoDB Atlas ─────────────────────────────────────────────────
MONGODB_URI=YOUR_MONGODB_ATLAS_URI
MONGODB_DATABASE=myukura_careops_demo
MONGODB_CONNECT_TIMEOUT_MS=5000
MONGODB_APP_NAME=myukura-careops-memory-agent

# ── Gemini Orchestrator ───────────────────────────────────────────
GEMINI_ENABLED=false
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_PRIMARY_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash
GEMINI_MAX_MODEL_ATTEMPTS=3
GEMINI_REQUEST_TIMEOUT_SECONDS=20

# ── CORS ──────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
