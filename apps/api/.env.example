# Core API Configuration
APP_ENV=local
STATE_BACKEND=memory
DEMO_MODE=true
DEMO_ACCESS_CODE=CHANGE_ME_FOR_DEMO
DEMO_ACCESS_REQUIRED=true
MAX_SOURCE_NOTE_CHARS=6000

# MongoDB Configuration
MONGODB_URI=MONGODB_URI_NOT_CONFIGURED

# Gemini Orchestrator Configuration
GEMINI_ENABLED=false
GEMINI_API_KEY=GEMINI_API_KEY_NOT_CONFIGURED
GEMINI_PRIMARY_MODEL=GEMINI_MODEL_NOT_CONFIGURED
GEMINI_FALLBACK_MODELS=
GEMINI_MAX_MODEL_ATTEMPTS=3
GEMINI_REQUEST_TIMEOUT_SECONDS=20

# CORS for local frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
