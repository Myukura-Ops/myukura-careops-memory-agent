# Phase 0 Skeletons do not require real credentials

# Phase 1 / Local Default
STATE_BACKEND=memory

# Phase 2 MongoDB Configuration
# (For MongoDB-backed demo, use STATE_BACKEND=mongodb)
MONGODB_URI=PHASE_2_PLACEHOLDER
MONGODB_DATABASE=myukura_careops_demo
MONGODB_CONNECT_TIMEOUT_MS=5000
MONGODB_APP_NAME=myukura-careops-memory-agent

# Demo Flags
DEMO_MODE=true

# Gemini Configuration
GEMINI_ENABLED=false
GEMINI_PROVIDER=developer_api
GEMINI_API_KEY=PHASE_3_PLACEHOLDER
GEMINI_PRIMARY_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODEL=PHASE_3_FALLBACK_MODEL_PLACEHOLDER
GEMINI_SECONDARY_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_RETRIES=2
GOOGLE_CLOUD_PROJECT=PHASE_3_PLACEHOLDER
GOOGLE_CLOUD_LOCATION=us-central1

# Phase 4 Placeholders
MONGODB_MCP_SERVER_URL=PHASE_4_PLACEHOLDER

# Partner Integrations / Observability
PARTNER_OUTBOX_ENABLED=true
PARTNER_MAX_ATTEMPTS=3
PARTNER_EXPORT_TIMEOUT_SECONDS=10

ARIZE_EXPORT_ENABLED=false
ARIZE_MCP_ENABLED=false
ARIZE_ENDPOINT=
ARIZE_API_KEY=

ELASTIC_EXPORT_ENABLED=false
ELASTIC_MCP_ENABLED=false
ELASTIC_ENDPOINT=
ELASTIC_API_KEY=

# App Config
API_PORT=8000
WORKER_PORT=8001
FRONTEND_PORT=5173
