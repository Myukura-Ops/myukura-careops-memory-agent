# ─── MyuKura CareOps Memory Agent ─── Environment Variables ───────────

# ── Core ──────────────────────────────────────────────────────────────
STATE_BACKEND=memory                          # "memory" (offline testing) or "mongodb" (Atlas)
APP_ENV=local
DEMO_MODE=true
DEMO_ACCESS_CODE=CHANGE_ME_FOR_DEMO           # Required: access code for protected endpoints
DEMO_ACCESS_REQUIRED=true

# ── MongoDB Atlas ─────────────────────────────────────────────────────
MONGODB_URI=YOUR_MONGODB_ATLAS_URI            # e.g. mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_DATABASE=myukura_careops_demo
MONGODB_CONNECT_TIMEOUT_MS=5000
MONGODB_APP_NAME=myukura-careops-memory-agent

# ── Gemini AI Orchestrator ────────────────────────────────────────────
GEMINI_ENABLED=false                          # Set true + provide API key to enable AI extraction
GEMINI_API_KEY=YOUR_GEMINI_API_KEY            # Google AI Studio API key
GEMINI_PRIMARY_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-3.5-pro
GEMINI_MAX_MODEL_ATTEMPTS=3
GEMINI_REQUEST_TIMEOUT_SECONDS=20

# ── CORS ──────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Partner Integrations (Outbox Pattern) ─────────────────────────────
PARTNER_OUTBOX_ENABLED=true
PARTNER_MAX_ATTEMPTS=3
PARTNER_EXPORT_TIMEOUT_SECONDS=10

ARIZE_EXPORT_ENABLED=false
ARIZE_MCP_ENABLED=false
ARIZE_ENDPOINT=
ARIZE_API_KEY=

ELASTIC_EXPORT_ENABLED=false
ELASTIC_MCP_ENABLED=false
ELASTIC_ENDPOINT=
ELASTIC_API_KEY=
ELASTIC_INDEX=myukura-careops-audit

# ── Official MongoDB MCP Server (read-only memory reads) ─────────────
MONGODB_MCP_ENABLED=false
MONGODB_MCP_COMMAND=npx
MONGODB_MCP_ARGS=-y,mongodb-mcp-server@latest,--readOnly
MONGODB_MCP_STARTUP_TIMEOUT_SECONDS=20
MONGODB_MCP_CALL_TIMEOUT_SECONDS=10

# ── Observability (Optional) ─────────────────────────────────────────
OBSERVABILITY_ENABLED=false
OBSERVABILITY_PROVIDER=none
DYNATRACE_ENABLED=false
